# VS Code Local History extension
/.history/

# Gradle cache written by docToolchain runs
/.gradle/

# Transient working material: upstream snapshots, handoffs, downloads.
# The folder itself is kept (via .gitkeep) as a landing zone; its contents are ignored.
/.temp/*
!/.temp/.gitkeep

# Generated Claude Code skill mirror. Source of truth is shared/skills/.
# Rebuild after clone or after editing a skill:  pwsh scripts/sync-skills.ps1
/.claude/commands/*

# Generated Codex skill mirror. Source of truth is shared/skills/.
# Rebuild after clone or after editing a skill:  pwsh scripts/sync-skills.ps1
/.agents/skills/*

# Python bytecode caches (e.g. from running the mail-to-doc tool's test suite)
__pycache__/
*.pyc

# NOTE: .scratch/ is intentionally NOT ignored — it is the local-markdown issue
# tracker (PRDs + issues live there and are meant to be committed).
