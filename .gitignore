# OS-generated files
.DS_Store
.DS_Store?
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
.Spotlight-V100/
.Trashes/
._*

# Editor / IDE metadata
/.idea/
*.iml
*.swp
*.swo
*~

# VS Code Local History extension
/.history/

# Gradle cache written by docToolchain runs
/.gradle/

# Transient working material: upstream snapshots, handoffs, downloads.
# The folder itself is kept (via .gitkeep) as a landing zone; its contents are ignored.
/.temp/*
!/.temp/.gitkeep

# Generated agent skill mirrors (Claude Code, Codex, Copilot). Source of truth is ai-artifacts/skills/shared/.
# Rebuild after clone or after editing a skill:  pwsh scripts/setup-repo.ps1 -SkipHooks
# One-step clone bootstrap: pwsh scripts/setup-repo.ps1
# Claude Code skill mirrors
/.claude/commands/**
!/.claude/commands/setup/
!/.claude/commands/setup/setup-repo/
!/.claude/commands/setup/setup-repo/**
!/.claude/commands/setup/setup-repo.md
# Codex skill mirrors
/.agents/skills/**
!/.agents/skills/setup_setup-repo/
!/.agents/skills/setup_setup-repo/**
# Copilot skill mirrors
/.github/skills/**
!/.github/skills/setup_setup-repo/
!/.github/skills/setup_setup-repo/**

# Python bytecode caches (e.g. from running the mail-to-doc tool's test suite)
__pycache__/
*.pyc

# NOTE: .scratch/ is intentionally NOT ignored — it is the local-markdown issue
# tracker (PRDs + issues live there and are meant to be committed).
