        "panel": "dedicated",
        "focus": false,
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Bootstrap repo mirrors and hooks (full refresh)",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-File",
        ".github/skills/setup_setup-repo/scripts/Invoke-SetupRepo.ps1"
      ],
      "problemMatcher": []
    }
  ]
